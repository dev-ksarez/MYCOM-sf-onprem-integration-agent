<?xml version="1.0" encoding="UTF-8"?>
<Layout xmlns="http://soap.sforce.com/2006/04/metadata">
    <layoutSections>
        <customLabel>false</customLabel>
        <detailHeading>true</detailHeading>
        <editHeading>true</editHeading>
        <label>Schedule Information</label>
        <layoutColumns>
            <layoutItems>
                <field>Name</field>
            </layoutItems>
            <layoutItems>
                <field>Active__c</field>
            </layoutItems>
            <layoutItems>
                <field>MSD_Connector__c</field>
            </layoutItems>
            <layoutItems>
                <field>ObjectName__c</field>
            </layoutItems>
            <layoutItems>
                <field>Operation__c</field>
            </layoutItems>
        </layoutColumns>
        <layoutColumns>
            <layoutItems>
                <field>SourceSystem__c</field>
            </layoutItems>
            <layoutItems>
                <field>TargetSystem__c</field>
            </layoutItems>
            <layoutItems>
                <field>MSD_Direction__c</field>
            </layoutItems>
            <layoutItems>
                <field>MSD_SourceType__c</field>
            </layoutItems>
            <layoutItems>
                <field>MSD_TargetType__c</field>
            </layoutItems>
        </layoutColumns>
        <style>TwoColumnsTopToBottom</style>
    </layoutSections>
    <layoutSections>
        <customLabel>false</customLabel>
        <detailHeading>true</detailHeading>
        <editHeading>true</editHeading>
        <label>Execution Settings</label>
        <layoutColumns>
            <layoutItems>
                <field>BatchSize__c</field>
            </layoutItems>
            <layoutItems>
                <field>NextRunAt__c</field>
            </layoutItems>
            <layoutItems>
                <field>LastRunAt__c</field>
            </layoutItems>
        </layoutColumns>
        <layoutColumns>
            <layoutItems>
                <field>MSD_SourceDefinition__c</field>
            </layoutItems>
            <layoutItems>
                <field>MSD_MappingDefinition__c</field>
            </layoutItems>
            <layoutItems>
                <field>MSD_TargetDefinition__c</field>
            </layoutItems>
        </layoutColumns>
        <style>TwoColumnsTopToBottom</style>
    </layoutSections>
    <relatedLists>
        <fields>Name</fields>
        <fields>MSD_Status__c</fields>
        <fields>MSD_StartedAt__c</fields>
        <fields>MSD_FinishedAt__c</fields>
        <relatedList>MSD_Run__c.MSD_Schedule__c</relatedList>
    </relatedLists>
    <relatedLists>
        <fields>Name</fields>
        <fields>MSD_ObjectName__c</fields>
        <fields>MSD_LastCheckpoint__c</fields>
        <fields>MSD_LastRecordId__c</fields>
        <relatedList>MSD_Checkpoint__c.MSD_Schedule__c</relatedList>
    </relatedLists>
    <showEmailCheckbox>false</showEmailCheckbox>
    <showHighlightsPanel>true</showHighlightsPanel>
    <showInteractionLogPanel>false</showInteractionLogPanel>
    <showRunAssignmentRulesCheckbox>false</showRunAssignmentRulesCheckbox>
    <showSubmitAndAttachButton>false</showSubmitAndAttachButton>
</Layout>
