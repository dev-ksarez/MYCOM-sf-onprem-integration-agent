<?xml version="1.0" encoding="UTF-8"?>
<Layout xmlns="http://soap.sforce.com/2006/04/metadata">
    <layoutSections>
        <customLabel>false</customLabel>
        <detailHeading>true</detailHeading>
        <editHeading>true</editHeading>
        <label>Run Overview</label>
        <layoutColumns>
            <layoutItems>
                <field>Name</field>
            </layoutItems>
            <layoutItems>
                <field>MSD_Schedule__c</field>
            </layoutItems>
            <layoutItems>
                <field>MSD_Status__c</field>
            </layoutItems>
            <layoutItems>
                <field>MSD_StartedAt__c</field>
            </layoutItems>
            <layoutItems>
                <field>MSD_FinishedAt__c</field>
            </layoutItems>
        </layoutColumns>
        <layoutColumns>
            <layoutItems>
                <field>MSD_CorrelationId__c</field>
            </layoutItems>
            <layoutItems>
                <field>MSD_AgentId__c</field>
            </layoutItems>
            <layoutItems>
                <field>MSD_RecordsRead__c</field>
            </layoutItems>
            <layoutItems>
                <field>MSD_RecordsProcessed__c</field>
            </layoutItems>
            <layoutItems>
                <field>MSD_RecordsSucceeded__c</field>
            </layoutItems>
            <layoutItems>
                <field>MSD_RecordsFailed__c</field>
            </layoutItems>
        </layoutColumns>
        <style>TwoColumnsTopToBottom</style>
    </layoutSections>
    <layoutSections>
        <customLabel>false</customLabel>
        <detailHeading>true</detailHeading>
        <editHeading>true</editHeading>
        <label>Error Details</label>
        <layoutColumns>
            <layoutItems>
                <field>MSD_ErrorMessage__c</field>
            </layoutItems>
        </layoutColumns>
        <layoutColumns/>
        <style>TwoColumnsTopToBottom</style>
    </layoutSections>
    <relatedLists>
        <fields>Name</fields>
        <fields>MSD_Level__c</fields>
        <fields>MSD_Step__c</fields>
        <fields>MSD_Message__c</fields>
        <relatedList>MSD_Log__c.MSD_Run__c</relatedList>
    </relatedLists>
    <relatedLists>
        <fields>Name</fields>
        <fields>MSD_ObjectName__c</fields>
        <fields>MSD_LastCheckpoint__c</fields>
        <fields>MSD_LastRecordId__c</fields>
        <relatedList>MSD_Checkpoint__c.MSD_Run__c</relatedList>
    </relatedLists>
    <showEmailCheckbox>false</showEmailCheckbox>
    <showHighlightsPanel>true</showHighlightsPanel>
    <showInteractionLogPanel>false</showInteractionLogPanel>
    <showRunAssignmentRulesCheckbox>false</showRunAssignmentRulesCheckbox>
    <showSubmitAndAttachButton>false</showSubmitAndAttachButton>
</Layout>
